{
  "name": "@sk-web-gui/web-app-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "yarn generate:middleware-envs",
    "dev": "cross-env TEST=true next dev",
    "prebuild": "yarn generate:middleware-envs",
    "build": "next build",
    "prebuild:test": "yarn generate:middleware-envs",
    "build:test": "cross-env TEST=true next build",
    "start": "next start",
    "generate:middleware-envs": "node middleware-envs-generator.mjs",
    "generate:contracts": "cross-env NODE_ENV=development npx tsx ./src/swagger-typescript-api.ts",
    "lint": "next lint --no-cache",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "cypress": "cypress open",
    "cypress:headless": "cross-env TEST=true npx cypress run --component && npx cypress run --e2e",
    "jest": "jest --watch",
    "jest:coverage": "jest --coverage",
    "test": "concurrently \"yarn jest\" \"yarn cypress\"",
    "coverage": "yarn nyc report --reporter=text-summary",
    "coverage:merge": "istanbul-merge --out coverage/summary/coverage-final.json coverage/cypress/coverage-final.json coverage/jest/coverage-final.json && nyc report --reporter=lcov -t coverage/summary --report-dir coverage/summary --check-coverage false",
    "test:coverage": "yarn cypress:headless && yarn jest:coverage && yarn coverage:merge",
    "type-check": "tsc --pretty --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@rjsf/core": "^5.24.13",
    "@rjsf/utils": "^5.24.13",
    "@rjsf/validator-ajv8": "^5.24.13",
    "@sk-web-gui/core": "4.3.3",
    "@sk-web-gui/react": "3.0.9",
    "@sk-web-gui/text-editor": "^2.0.2",
    "@sk-web-gui/alert": "^1.1.2",
    "@tailwindcss/forms": "^0.5.10",
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "axios": "^1.13.5",
    "dayjs": "^1.11.19",
    "i18next": "^24.2.3",
    "i18next-resources-to-backend": "^1.2.1",
    "lodash": "4.17.21",
    "lucide-react": "0.576.0",
    "next": "16.1.6",
    "next-i18n-router": "^5.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^15.6.1",
    "sass": "^1.94.0",
    "sharp": "^0.34.5",
    "yup": "^1.7.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/plugin-transform-private-methods": "^7.25.9",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.27.0",
    "@cypress/code-coverage": "^3.14.0",
    "@eslint/js": "^8.57.1",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@simonsmith/cypress-image-snapshot": "^10.0.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.0",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "@types/underscore.string": "^0.0.41",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "cypress": "^14.2.1",
    "dotenv": "^16.4.7",
    "envalid": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "identity-obj-proxy": "^3.0.0",
    "istanbul-merge": "^2.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^7.0.2",
    "postcss-nesting": "^13.0.1",
    "prettier": "^3.5.3",
    "swagger-typescript-api": "^13.0.28",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.3.1",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.29.0"
  },
  "browserslist": [
    "defaults and fully supports es6-module"
  ]
}
